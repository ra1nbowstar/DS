# ========================================
# 环境标识（重要：必须设置为 development 或 testing）
# ========================================
ENVIRONMENT=development

# ========================================
# 数据库配置（测试环境）
# ========================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=database

# ========================================
# JWT配置（测试环境）
# ========================================
# 测试用密钥，生产环境必须更换为强随机字符串
JWT_SECRET_KEY=dev-secret-key-32-chars-long-for-testing
# Token过期时间（分钟），测试环境可设置长一些（7天=10080分钟）
JWT_EXPIRE_MINUTES=10080
# 1=启用UUID认证（测试环境），0=仅JWT（生产环境）
ENABLE_UUID_AUTH=1

# ========================================
# 银行卡加密配置（必须设置）
# ========================================
# 用于卡号哈希加密，测试环境可自定义，生产环境必须使用强随机盐
CARD_SALT=test_salt_2024_32_chars_for_dev_only

# ========================================
# 微信支付配置（MOCK模式下可随意填写）
# ========================================
# true = 启用模拟（无需真实微信账户），false = 调用真实接口
WX_MOCK_MODE=true

# 默认为true，建议别改，2024年前创建的商户可以改成false
WX_USE_PUB_KEY_ID_MODE=true

# 以下配置在 MOCK_MODE=true 时不会实际使用，但必须存在
# 须与「微信小程序后台 - 微信支付」里显示的商户号一致，否则支付成功但发货管理里搜不到单
WECHAT_PAY_MCH_ID=1620000000
WECHAT_PAY_API_V3_KEY=apiv3key
WECHAT_PAY_API_CERT_PATH=./certs/apiclient_cert.pem
WECHAT_PAY_API_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_PUB_KEY_ID=PUB_KEY_ID_00000000000000000
WECHAT_PAY_PUBLIC_KEY_PATH=./certs/pub_key.pem
WECHAT_CERT_SERIAL_NO=MOCK_SERIAL_NO
WECHAT_PAY_NOTIFY_URL=https://test-domain.com/api/wechat-pay/notify

# ========================================
# 微信小程序配置（MOCK模式下可随意填写）
# ========================================
# 须与当前小程序 AppID 一致（与下单 JSAPI 里 appid 相同）
WECHAT_APP_ID=wx00000000000
WECHAT_APP_SECRET=00000000000000
# 小程序码 env_version：release（正式）/ trial（体验）/ develop（开发）。本地真机/开发者工具调试未发正式版时可设为 develop
WECHAT_WXA_ENV_VERSION=release
# 小程序「开发管理 - 消息推送」配置的 Token，用于 /wechat-wxa/msg 校验（与支付回调 URL 不同）
WECHAT_WXA_MSG_TOKEN=

# ========================================
# 业务配置
# ========================================
# 进件草稿过期天数
DRAFT_EXPIRE_DAYS=7
# 最大文件上传大小（MB）
MAX_FILE_SIZE_MB=10
# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=DEBUG

# ========================================
# 推送模板ID（如需测试推送功能，需填写真实值）
# ========================================
PUSH_TEMPLATE_ID_APPLYMENT=xxxxx

# ========================================
# 服务器配置
# ========================================
UVICORN_PORT=8000

# ========================================
# 微信V3 API兼容配置（可保持默认值）
# ========================================
# 这些配置主要用于向后兼容，建议统一使用 WECHAT_PAY_* 前缀
WX_MCHID=1620000000
WX_CERT_SERIAL_NO=MOCK_CERT_SERIAL
WX_APIV3_KEY=YourWxapiV3Key
WX_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WX_WECHATPAY_SERIAL=MOCK_WECHATPAY_SERIAL
WX_PAY_BASE_URL=https://api.mch.weixin.qq.com

# ========================================
# MOCK测试配置（可选）
# ========================================
# 模拟进件审核结果：SUCCESS=审核通过，FAIL=审核失败
# 用于测试改绑失败场景
WX_MOCK_APPLY_RESULT=SUCCESS

# ========================================
# 微信支付服务商配置（真实环境）
# ========================================
WECHAT_PAY_SP_MCH_ID=your_service_provider_mchid
WECHAT_PAY_SP_APPID=your_service_provider_appid
WX_SETTLE_RULE_ID=your_settlement_rule_id  # 默认 76011 或从商户平台查询的真实ID

# ========================================
# 主机 / 域名配置（用于构建普通二维码的链接）
# ========================================
# 接口会生成类似（普通二维码统一 /offline?id=；兼容旧链 /pay-bridge?id=；旧版仍可用 /api/offline/permanentPay）
#   https://<your-domain>/offline?id=123
# 若 HOST 留空，会尝试从 WECHAT_PAY_NOTIFY_URL 解析站点根（scheme+主机）。
HOST=

# ========================================
# 生产环境补充配置（必须）
# ========================================

# ========================================
# 银行卡安全策略（可选但建议）
# ========================================
# 验证码有效期（分钟，默认5）
BANKCARD_CODE_EXPIRE_MINUTES=5
# 单日最大发送次数（防刷）
BANKCARD_MAX_DAILY_ATTEMPTS=10
# 验证码长度（默认6）
BANKCARD_CODE_LENGTH=6

# ========================================
# 风控配置（生产环境建议）
# ========================================
# 同一银行卡最大绑定用户数（防洗钱）
MAX_CARD_BIND_USERS=1
# 绑定操作IP频率限制（次/小时）
BIND_RATE_LIMIT_PER_HOUR=10
# 同一用户每小时最多绑定次数
BIND_RATE_LIMIT_PER_USER_PER_HOUR=5